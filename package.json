{
    "name": "saif-control",
    "version": "1.0.0",
    "private": true,
    "description": "Saif Control System — Next-generation FiveM server management platform",
    "workspaces": [
        "packages/*",
        "apps/*",
        "services/*"
    ],
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "dev:web": "cd apps/web && npm run dev",
        "dev:api": "cd apps/api && npm run start:dev",
        "dev:agent": "cd services/agent && npm run start:dev",
        "db:migrate": "cd apps/api && npx prisma migrate dev",
        "db:seed": "cd apps/api && npx prisma db seed",
        "docker:up": "docker-compose up -d",
        "docker:down": "docker-compose down"
    },
    "devDependencies": {
        "turbo": "^2.3.0",
        "typescript": "^5.7.0"
    },
    "packageManager": "npm@10.9.4",
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "effect": "^3.19.19",
        "rxjs": "^7.8.2"
    }
}
