{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "./dist",
        "rootDir": "./src",
        "target": "ES2022",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "declaration": true,
        "strictNullChecks": true,
        "noImplicitAny": true
    },
    "include": [
        "src/**/*"
    ]
}