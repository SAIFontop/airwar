// Prisma Schema for Saif Control System
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ───────────────────────────────────────────────
model User {
  id          String   @id @default(uuid())
  username    String   @unique
  email       String   @unique
  password    String
  role        Role     @default(OBSERVER)
  avatar      String?
  mfaEnabled  Boolean  @default(false)
  mfaSecret   String?
  permissions String[]
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions     Session[]
  apiTokens    ApiToken[]
  auditLogs    AuditLog[]
  playerActions PlayerAction[]

  @@map("users")
}

enum Role {
  OWNER
  ADMINISTRATOR
  DEVELOPER
  MODERATOR
  OBSERVER
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String
  userAgent String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model ApiToken {
  id        String   @id @default(uuid())
  userId    String
  name      String
  token     String   @unique
  scopes    String[]
  expiresAt DateTime?
  lastUsed  DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_tokens")
}

// ─── Server ────────────────────────────────────────────────────
model Server {
  id             String       @id @default(uuid())
  name           String
  hostname       String
  port           Int          @default(30120)
  maxPlayers     Int          @default(48)
  gameBuild      String       @default("3095")
  serverDataPath String
  cfgPath        String
  autoRestart    Boolean      @default(true)
  scheduledRestarts String[]
  tags           String[]
  status         ServerStatus @default(OFFLINE)
  pid            Int?
  version        String?
  clusterId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  players       Player[]
  alerts        Alert[]
  automationRules AutomationRule[]
  auditLogs     AuditLog[]

  @@map("servers")
}

enum ServerStatus {
  ONLINE
  OFFLINE
  STARTING
  STOPPING
  CRASHED
  RESTARTING
  UPDATING
}

// ─── Player ────────────────────────────────────────────────────
model Player {
  id           String   @id @default(uuid())
  serverId     String
  fivemId      Int
  name         String
  steam        String?
  license      String?
  license2     String?
  discord      String?
  fivem        String?
  xbl          String?
  live         String?
  totalPlaytime Int     @default(0)
  joinCount    Int      @default(0)
  lastSeen     DateTime @default(now())
  notes        String[]
  flags        String[]
  isBanned     Boolean  @default(false)
  banExpiry    DateTime?
  banReason    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  server  Server         @relation(fields: [serverId], references: [id], onDelete: Cascade)
  actions PlayerAction[]

  @@unique([serverId, fivemId])
  @@map("players")
}

model PlayerAction {
  id        String   @id @default(uuid())
  playerId  String
  adminId   String
  type      ActionType
  reason    String
  duration  Int?
  metadata  Json?
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  admin  User   @relation(fields: [adminId], references: [id])

  @@map("player_actions")
}

enum ActionType {
  KICK
  BAN
  WARN
  MUTE
  FREEZE
  TELEPORT
  SPECTATE
  UNBAN
}

// ─── Alerts ────────────────────────────────────────────────────
model Alert {
  id             String        @id @default(uuid())
  serverId       String
  severity       AlertSeverity
  title          String
  message        String
  acknowledged   Boolean       @default(false)
  acknowledgedBy String?
  resolvedAt     DateTime?
  metadata       Json?
  createdAt      DateTime      @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ─── Automation ────────────────────────────────────────────────
model AutomationRule {
  id            String   @id @default(uuid())
  name          String
  description   String   @default("")
  enabled       Boolean  @default(true)
  serverId      String?
  triggerType   String
  conditions    Json
  cooldown      Int      @default(60)
  actions       Json
  lastTriggered DateTime?
  triggerCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  server Server? @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@map("automation_rules")
}

// ─── Audit Log ─────────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  serverId  String?
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  server Server? @relation(fields: [serverId], references: [id])

  @@map("audit_logs")
}
